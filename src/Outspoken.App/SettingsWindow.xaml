<Window x:Class="Outspoken.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Outspoken" Width="504" SizeToContent="Height" UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" Foreground="#26241F">
  <Window.Resources>

    <!-- iOS-style toggle switch (drop-in for CheckBox) with a soft animated slide -->
    <Style x:Key="Toggle" TargetType="CheckBox">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Border x:Name="Track" Width="42" Height="24" CornerRadius="12">
              <Border.Background>
                <SolidColorBrush x:Name="TrackBrush" Color="#DDD5C7" />
              </Border.Background>
              <Ellipse x:Name="Knob" Width="18" Height="18" Fill="White"
                       HorizontalAlignment="Left" Margin="3,0,0,0">
                <Ellipse.RenderTransform>
                  <TranslateTransform x:Name="KnobShift" X="0" />
                </Ellipse.RenderTransform>
                <Ellipse.Effect>
                  <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="4" ShadowDepth="1" Direction="270" />
                </Ellipse.Effect>
              </Ellipse>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="KnobShift" Storyboard.TargetProperty="X"
                                       To="18" Duration="0:0:0.18">
                        <DoubleAnimation.EasingFunction>
                          <CubicEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                      <ColorAnimation Storyboard.TargetName="TrackBrush" Storyboard.TargetProperty="Color"
                                      To="#C2571B" Duration="0:0:0.18" />
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="KnobShift" Storyboard.TargetProperty="X"
                                       To="0" Duration="0:0:0.18">
                        <DoubleAnimation.EasingFunction>
                          <CubicEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                      <ColorAnimation Storyboard.TargetName="TrackBrush" Storyboard.TargetProperty="Color"
                                      To="#DDD5C7" Duration="0:0:0.18" />
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- A settings row: label + hint on the left, control on the right -->
    <Style x:Key="RowTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13.5" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style x:Key="RowHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="#9E9384" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Margin" Value="0,2,0,0" />
    </Style>
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#B0A491" />
      <Setter Property="Margin" Value="4,0,0,7" />
    </Style>

    <!-- Soft card -->
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="#FFFDFA" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BorderBrush" Value="#EDE7DB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="18,4" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect Color="#B8AE9C" Opacity="0.16" BlurRadius="14" ShadowDepth="1" Direction="270" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#C2571B" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="9">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="B" Property="Background" Value="#A84A15" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
      <Setter Property="Foreground" Value="#6B6355" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="B" Background="Transparent" CornerRadius="9" BorderBrush="#E0D8C9" BorderThickness="1">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="B" Property="Background" Value="#F1ECE2" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <!-- Rounded window shell. The 22px transparent margin gives the drop shadow room to render as a
       soft rounded halo, and guarantees the rounded corners are inset from the (square) window edge
       so SizeToContent can never clip the rounded bottom into a straight line. -->
  <Border CornerRadius="18" Background="#F7F3EC" BorderBrush="#E7E0D3" BorderThickness="1" Margin="22"
          MouseLeftButtonDown="OnWindowDrag">
    <Border.Effect>
      <DropShadowEffect Color="#000000" Opacity="0.28" BlurRadius="26" ShadowDepth="3" Direction="270" />
    </Border.Effect>

    <Grid Margin="26,20,26,22">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Header. The whole window is draggable (handler on the root Border); interactive
           controls mark their clicks handled, so they still work. -->
      <Grid Grid.Row="0" x:Name="HeaderBar" Background="Transparent">
        <StackPanel Orientation="Horizontal">
          <!-- Brand mark: "Mic & Halo" (injected from BrandMark; the app-icon squircle variant) -->
          <ContentControl x:Name="LogoHost" Width="42" Height="42" VerticalAlignment="Center" Margin="0,0,12,0" />
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Outspoken" FontSize="21" FontWeight="SemiBold" />
            <TextBlock Text="Dictation without limits" Foreground="#A99D8B" FontSize="12" Margin="0,1,0,0" />
          </StackPanel>
        </StackPanel>
        <Button Content="✕" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top"
                Style="{StaticResource GhostButton}" FontSize="12" Click="OnCancel" />
      </Grid>

      <!-- Body -->
      <StackPanel Grid.Row="1" Margin="0,20,0,0">

        <TextBlock Text="API KEY" Style="{StaticResource SectionLabel}" />
        <Border Style="{StaticResource Card}" Padding="18,16">
          <StackPanel>
            <TextBlock x:Name="KeyStatus" FontSize="12.5" FontWeight="Medium" />
            <PasswordBox x:Name="ApiKeyBox" Padding="9,7" FontSize="12" Margin="0,10,0,0"
                         BorderBrush="#E2DBCC" Background="White" />
            <TextBlock Style="{StaticResource RowHint}" Margin="0,8,0,0"
                       Text="Anthropic key, encrypted on this device (Windows DPAPI). Leave blank to keep the current key. Cleanup runs on your key; without one, dictation still works in raw mode." />
          </StackPanel>
        </Border>

        <TextBlock Text="DICTATION" Style="{StaticResource SectionLabel}" Margin="4,20,0,7" />
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <Grid Margin="0,14">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Hotkey" Style="{StaticResource RowTitle}" />
                <TextBlock Style="{StaticResource RowHint}" Text="Hold to talk · +Shift for raw" />
              </StackPanel>
              <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#F1ECE2"
                      CornerRadius="7" Padding="10,5">
                <TextBlock Text="Ctrl + Win" FontSize="12.5" FontWeight="SemiBold" Foreground="#5E5648" />
              </Border>
            </Grid>
            <Border Height="1" Background="#F0EADE" />
            <Grid Margin="0,14">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Raw by default" Style="{StaticResource RowTitle}" />
                <TextBlock Style="{StaticResource RowHint}" Text="Skip the LLM cleanup pass" />
              </StackPanel>
              <CheckBox x:Name="RawDefaultCheck" Style="{StaticResource Toggle}"
                        HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
            <Border Height="1" Background="#F0EADE" />
            <StackPanel Margin="0,14">
              <TextBlock Text="Custom vocabulary" Style="{StaticResource RowTitle}" />
              <TextBlock Style="{StaticResource RowHint}"
                         Text="Names and terms you dictate that get misheard - product names, jargon, people. Comma or line-separated. Stored locally on this device; improves transcription of these words." />
              <TextBox x:Name="VocabularyBox" Margin="0,9,0,0" Padding="9,7" FontSize="12"
                       MinHeight="56" MaxHeight="120" TextWrapping="Wrap" AcceptsReturn="True"
                       VerticalScrollBarVisibility="Auto" BorderBrush="#E2DBCC" Background="White" />
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock Text="EXPERIENCE" Style="{StaticResource SectionLabel}" Margin="4,20,0,7" />
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <Grid Margin="0,14">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Sound cues" Style="{StaticResource RowTitle}" />
                <TextBlock Style="{StaticResource RowHint}" Text="Soft start / stop tones" />
              </StackPanel>
              <CheckBox x:Name="CuesCheck" Style="{StaticResource Toggle}"
                        HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
            <Border Height="1" Background="#F0EADE" />
            <Grid Margin="0,14">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Launch at login" Style="{StaticResource RowTitle}" />
                <TextBlock Style="{StaticResource RowHint}" Text="Start Outspoken when I sign in" />
              </StackPanel>
              <CheckBox x:Name="LaunchCheck" Style="{StaticResource Toggle}"
                        HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Footer -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
        <Button Content="Cancel" Width="92" Height="36" Margin="0,0,10,0"
                Style="{StaticResource GhostButton}" Click="OnCancel" />
        <Button Content="Save" Width="92" Height="36" Style="{StaticResource PrimaryButton}" Click="OnSave" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
