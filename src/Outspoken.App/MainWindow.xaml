<Window x:Class="Outspoken.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Outspoken — Diagnostics" Height="420" Width="800"
        WindowStartupLocation="CenterScreen">
  <DockPanel Margin="8">
    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#666"
               Text="Live diagnostics. Outspoken runs from the system tray — hold Ctrl+Win anywhere to dictate. Closing this window keeps the app running in the tray." />
    <ListBox x:Name="EventLog" FontFamily="Consolas" />
  </DockPanel>
</Window>
