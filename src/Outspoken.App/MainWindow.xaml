<Window x:Class="Outspoken.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Outspoken — walking skeleton (T7)" Height="400" Width="760">
  <DockPanel Margin="8">
    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap"
               Text="Wait for '✓ ready', focus any text field, hold Ctrl+Win and speak. Release → text at the cursor with a release→done timing line (raw target ≤1.5s). +Shift = raw mode." />
    <ListBox x:Name="EventLog" FontFamily="Consolas" />
  </DockPanel>
</Window>
