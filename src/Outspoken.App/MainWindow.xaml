<Window x:Class="Outspoken.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Outspoken — hotkey debug (T3)" Height="360" Width="560">
  <DockPanel Margin="8">
    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap"
               Text="Hold Ctrl+Win anywhere (this window does not need focus). +Shift = raw mode. Events log below; verify the combo types nothing into Notepad and the Start menu stays closed." />
    <ListBox x:Name="EventLog" FontFamily="Consolas" />
  </DockPanel>
</Window>
